# =============================================================================
# SALON SHAHD — Environment variables
# Copy to `.env` locally. In production, set these in the host (Vercel, Railway, etc.).
# Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Required everywhere
# -----------------------------------------------------------------------------
# PostgreSQL connection string (local, Neon, Supabase, Railway, RDS, etc.)
# Example (Neon): postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# -----------------------------------------------------------------------------
# Required in production (NODE_ENV=production)
# -----------------------------------------------------------------------------
# Auth.js v5 secret — generate: openssl rand -base64 32
AUTH_SECRET="your-secret-key-at-least-32-chars"
# Legacy alias (optional if AUTH_SECRET is set):
# NEXTAUTH_SECRET="same-as-auth-secret"

# Public canonical URL of the site — NO trailing slash
# Local: http://localhost:3000
# Production: https://www.your-salon-domain.com
# Used for Auth.js callbacks, emails, and absolute links.
AUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Optional — Twilio (SMS / WhatsApp customer notifications)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# SMS From (E.164)
TWILIO_PHONE_NUMBER=""
# WhatsApp From — Twilio sandbox or approved sender, e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=""

# -----------------------------------------------------------------------------
# Optional — SMTP (Nodemailer / email channel)
# -----------------------------------------------------------------------------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# -----------------------------------------------------------------------------
# Cron — appointment reminders (GET /api/cron/appointment-reminders)
# -----------------------------------------------------------------------------
# Random long string. External cron: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="generate-a-long-random-string"

# Vercel sets VERCEL=1 automatically. With Vercel Cron (vercel.json), requests
# include x-vercel-cron: 1 — no Bearer needed for that path.

# -----------------------------------------------------------------------------
# Optional — Rate limiting (multi-instance / serverless)
# -----------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# Required for gallery uploads in PRODUCTION (Vercel/serverless)
# -----------------------------------------------------------------------------
# Without these, admin gallery POST returns an error in production (local disk is not durable).
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Optional folder in Cloudinary:
# CLOUDINARY_GALLERY_FOLDER="salon-booking/gallery"

# -----------------------------------------------------------------------------
# Optional — dangerous dev-only route (default OFF in production)
# -----------------------------------------------------------------------------
# POST /api/test-whatsapp — admin only; in production enable only for debugging:
# ALLOW_ADMIN_TEST_WHATSAPP="true"
